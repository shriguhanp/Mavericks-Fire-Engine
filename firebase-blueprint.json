{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "photoURL": { "type": "string", "description": "The user's profile photo URL" },
        "createdAt": { "type": "timestamp", "description": "When the user was created" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Calculation": {
      "title": "Calculation",
      "description": "A saved FIRE calculation",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The owner's user ID" },
        "currentAge": { "type": "number", "description": "Current age" },
        "retirementAge": { "type": "number", "description": "Target retirement age" },
        "lifeExpectancy": { "type": "number", "description": "Life expectancy" },
        "monthlyExpenses": { "type": "number", "description": "Monthly expenses in retirement" },
        "currentSavings": { "type": "number", "description": "Current savings/investments" },
        "monthlyInvestment": { "type": "number", "description": "Monthly investment amount" },
        "monthlyIncome": { "type": "number", "description": "Monthly income amount" },
        "lifeGoals": { "type": "string", "description": "User's life goals" },
        "aiRoadmap": { "type": "string", "description": "AI generated financial roadmap" },
        "inflationRate": { "type": "number", "description": "Expected inflation rate" },
        "returnRate": { "type": "number", "description": "Expected return rate" },
        "safeWithdrawalRate": { "type": "number", "description": "Safe withdrawal rate" },
        "updatedAt": { "type": "timestamp", "description": "When the calculation was last updated" }
      },
      "required": ["uid", "currentAge", "retirementAge", "lifeExpectancy", "monthlyExpenses", "currentSavings", "monthlyInvestment", "inflationRate", "returnRate", "safeWithdrawalRate", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/calculations/{userId}": {
      "schema": { "$ref": "#/entities/Calculation" },
      "description": "User's saved FIRE calculation (one per user for now)"
    }
  }
}
